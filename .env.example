# postgres
POSTGRES_DATABASE=messenger
POSTGRES_USERNAME=
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=6000

# rustfs 
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
